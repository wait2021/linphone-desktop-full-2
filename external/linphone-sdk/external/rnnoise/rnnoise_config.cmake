if(NOT IOS AND NOT ANDROID AND NOT CMAKE_SYSTEM_PROCESSOR MATCHES "arm64|aarch64") #Do not change the behaviour for mobiles
  set(OPUS_HAVE_RTCD 1)
  set(RNN_HAVE_RTCD 1)
  set(CPU_INFO_BY_ASM 1)
  set(CPU_INFO_BY_C 1)
  add_definitions(-DOPUS_HAVE_RTCD)
  add_definitions(-DCPU_INFO_BY_ASM)
  add_definitions(-DCPU_INFO_BY_C)
  message(STATUS "RNN_HAVE_RTCD set")
endif()

if(CMAKE_SYSTEM_PROCESSOR MATCHES "(i[0-9]86|x86|X86|amd64|AMD64|x86_64)")
  if(CMAKE_SIZEOF_VOID_P EQUAL 8)
    set(RNN_CPU_X64 1)
  else()
    set(RNN_CPU_X86 1)
  endif()
elseif(CMAKE_SYSTEM_PROCESSOR MATCHES "(armv7-a|armv7|armv7s|arm64|aarch64)")
  set(RNN_CPU_ARM 1)
endif()

rnnoise_supports_cpu_detection(RUNTIME_CPU_CAPABILITY_DETECTION)

if(RNN_CPU_X86 OR RNN_CPU_X64)
  rnnoise_detect_sse(COMPILER_SUPPORT_SIMD)
elseif(RNN_CPU_ARM)
  rnnoise_detect_neon(COMPILER_SUPPORT_NEON)
  if(COMPILER_SUPPORT_NEON)
    option(RNN_USE_NEON "Option to turn off SSE for RNNoise" ON)
    option(RNN_MAY_HAVE_NEON "Does runtime check for neon support for RNNoise" ON)
    option(RNN_PRESUME_NEON "Assume target CPU has NEON support for RNNoise" OFF)
    if(CMAKE_SYSTEM_PROCESSOR MATCHES "(aarch64|arm64)")
      set(RNN_PRESUME_NEON ON)
      set(RNN_MAY_HAVE_NEON OFF)
    endif()
    if(CMAKE_OSX_ARCHITECTURES MATCHES "arm*")
      if(IOS)
        message(STATUS "Presuming NEON as iOS on ${CMAKE_OSX_ARCHITECTURES} detected for RNNoise.")
      elseif(APPLE)
        message(STATUS "Presuming NEON as Apple on ${CMAKE_OSX_ARCHITECTURES} detected for RNNoise.")
      else()
        message(STATUS "Presuming NEON as ${CMAKE_OSX_ARCHITECTURES} detected for RNNoise.")
      endif()
      set(RNN_PRESUME_NEON ON)
      set(RNN_MAY_HAVE_NEON OFF)
    endif()
  endif()
endif()
